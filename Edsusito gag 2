-- ========== ESTADO DEL SISTEMA ==========
local SystemState = {
    -- Farm
    AutoCollect = false,
    CollectMode = "All",
    SelectedFruit = "",
    Exceptions = {},
    CollectDelay = 1,
    
    -- Plant
    AutoPlant = false,
    PlantMode = "Below",
    PlantDelay = 1,
    LineMode_Count = 5,
    LineMode_Distance = 3,
    
    -- Player
    WalkSpeed = 16,
    JumpPower = 50,
    
    -- System
    IsRunning = true,
    DebugMode = false
}

-- ========== FUNCIONES AUXILIARES ==========

local function Debug(message)
    if SystemState.DebugMode then
        print("[EDSUSITO FARM DEBUG] " .. tostring(message))
    end
end

local function SafeCall(func, ...)
    local success, result = pcall(func, ...)
    if not success then
        Debug("Error: " .. tostring(result))
    end
    return success, result
end

-- ========== MÓDULO: FARM (RECOLECCIÓN) ==========

local FarmModule = {}

function FarmModule:ShouldCollect(fruitName)
    if SystemState.CollectMode == "All" then
        if table.find(SystemState.Exceptions, fruitName) then
            return false
        end
        return true
    elseif SystemState.CollectMode == "Specific" then
        return fruitName == SystemState.SelectedFruit
    end
    return false
end

function FarmModule:CollectLoop()
    Debug("Iniciando Farm Loop...")
    while SystemState.AutoCollect and SystemState.IsRunning do
        SafeCall(function()
            for _, v in pairs(workspace:GetDescendants()) do
                if SystemState.AutoCollect == false then break end
                
                if v:IsA("BasePart") and v.Parent then
                    local fruitName = v.Name
                    
                    if self:ShouldCollect(fruitName) then
                        -- LÓGICA DE RECOLECCIÓN
                        if v:FindFirstChild("ProximityPrompt") then
                            fireproximityprompt(v.ProximityPrompt)
                            Debug("Recolectando: " .. fruitName)
                        end
                    end
                end
            end
        end)
        
        task.wait(SystemState.CollectDelay)
    end
    Debug("Farm Loop detenido")
end

function FarmModule:Start()
    if not SystemState.AutoCollect then
        SystemState.AutoCollect = true
        task.spawn(function() self:CollectLoop() end)
    end
end

function FarmModule:Stop()
    SystemState.AutoCollect = false
end

-- ========== MÓDULO: PLANT (PLANTADO) ==========

local PlantModule = {}

function PlantModule:PlantAtPosition(position)
    SafeCall(function()
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            -- LÓGICA DE PLANTADO EN POSICIÓN
            Debug("Plantando en: " .. tostring(position))
        end
    end)
end

function PlantModule:PlantLoop()
    Debug("Iniciando Plant Loop...")
    while SystemState.AutoPlant and SystemState.IsRunning do
        SafeCall(function()
            local char = LocalPlayer.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                local root = char.HumanoidRootPart
                
                if SystemState.PlantMode == "Below" then
                    self:PlantAtPosition(root.Position)
                    
                elseif SystemState.PlantMode == "Line" then
                    for i = 1, SystemState.LineMode_Count do
                        if not SystemState.AutoPlant then break end
                        local offset = Vector3.new(i * SystemState.LineMode_Distance, 0, 0)
                        self:PlantAtPosition(root.Position + offset)
                        task.wait(0.1)
                    end
                    
                elseif SystemState.PlantMode == "Point" then
                    local fixedPoint = Vector3.new(0, 5, 0)
                    self:PlantAtPosition(fixedPoint)
                end
            end
        end)
        
        task.wait(SystemState.PlantDelay)
    end
    Debug("Plant Loop detenido")
end

function PlantModule:Start()
    if not SystemState.AutoPlant then
        SystemState.AutoPlant = true
        task.spawn(function() self:PlantLoop() end)
    end
end

function PlantModule:Stop()
    SystemState.AutoPlant = false
end

-- ========== MÓDULO: PLAYER ==========

local PlayerModule = {}

function PlayerModule:SetSpeed(value)
    SafeCall(function()
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            LocalPlayer.Character.Humanoid.WalkSpeed = value
            SystemState.WalkSpeed = value
            Debug("Velocidad establecida a: " .. value)
        end
    end)
end

function PlayerModule:Teleport(position)
    SafeCall(function()
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(position)
        end
    end)
end

